<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tydic.filehub.mapper.uoc.ConfigPullDatasourceMapper">

    <resultMap id="DatasourceMap" type="com.tydic.filehub.dto.ConfigPullDatasource">
        <id column="id" property="id"/>
        <result column="datasource_code" property="datasourceCode"/>
        <result column="data_ip" property="dataIp"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="drive_name" property="driveName"/>
        <result column="datasource_type" property="datasourceType"/>
        <result column="state" property="state"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <sql id="allColumns">
        id, datasource_code, data_ip, username, password, drive_name,
        datasource_type, state, create_time, update_time, remark
    </sql>

    <select id="selectByCode" resultMap="DatasourceMap">
        select <include refid="allColumns"/>
        from config_pull_datasource
        where datasource_code = #{datasourceCode}
          and state = 1
        limit 1
    </select>

    <select id="selectAnyByCode" resultMap="DatasourceMap">
        select <include refid="allColumns"/>
        from config_pull_datasource
        where datasource_code = #{datasourceCode}
        limit 1
    </select>

    <select id="selectAll" resultMap="DatasourceMap">
        select <include refid="allColumns"/>
        from config_pull_datasource
        <where>
            <if test="keyword != null and keyword != ''">
                and (
                    datasource_code like concat('%', #{keyword}, '%')
                    or ifnull(remark, '') like concat('%', #{keyword}, '%')
                )
            </if>
        </where>
        order by update_time desc, id desc
    </select>

    <insert id="insertSelective" parameterType="com.tydic.filehub.dto.ConfigPullDatasource" useGeneratedKeys="true" keyProperty="id">
        insert into config_pull_datasource
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="datasourceCode != null">datasource_code,</if>
            <if test="dataIp != null">data_ip,</if>
            <if test="username != null">username,</if>
            <if test="password != null">password,</if>
            <if test="driveName != null">drive_name,</if>
            <if test="datasourceType != null">datasource_type,</if>
            <if test="state != null">state,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="datasourceCode != null">#{datasourceCode},</if>
            <if test="dataIp != null">#{dataIp},</if>
            <if test="username != null">#{username},</if>
            <if test="password != null">#{password},</if>
            <if test="driveName != null">#{driveName},</if>
            <if test="datasourceType != null">#{datasourceType},</if>
            <if test="state != null">#{state},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="com.tydic.filehub.dto.ConfigPullDatasource">
        update config_pull_datasource
        <set>
            <if test="datasourceCode != null">datasource_code = #{datasourceCode},</if>
            <if test="dataIp != null">data_ip = #{dataIp},</if>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="driveName != null">drive_name = #{driveName},</if>
            <if test="datasourceType != null">datasource_type = #{datasourceType},</if>
            <if test="state != null">state = #{state},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where id = #{id}
    </update>
</mapper>
